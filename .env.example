# Copy this file to .env and fill in your values
# docker-compose reads .env automatically from the repo root

# Required for geocoding + Google Solar API
# Enable in Google Cloud Console:
#   - Solar API
#   - Geocoding API
GOOGLE_SOLAR_API_KEY=your_key_here

# Restrict enrichment (geocoding, solar, 990) to one state. Leave blank for all states.
# Default: KY — expand once you're ready to scale nationally
ENRICHMENT_STATE=KY

# Optional: override scheduler cron expressions (UTC)
# IRS_CHECK_CRON=0 2 * * *
# ENRICHMENT_CRON=0 */6 * * *
# INDEX_REFRESH_CRON=0 3 * * 0
# SOLAR_CRON=0 */4 * * *
