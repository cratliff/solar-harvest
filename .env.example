# Copy this file to .env and fill in your values
# docker-compose reads .env automatically from the repo root

# Free NREL PVWatts API key — sign up at https://developer.nrel.gov/signup/
# Falls back to DEMO_KEY (50 req/day) if not set.
NREL_API_KEY=your_key_here

# Optional: Google Maps Geocoding API key (paid fallback — Census geocoder is used when unset)
# Enable "Geocoding API" in Google Cloud Console.
GOOGLE_MAPS_API_KEY=

# Restrict enrichment to a state + optional city. Leave blank to process all states/cities.
# Default: KY / LEXINGTON — expand once you're ready to scale nationally
ENRICHMENT_STATE=KY
ENRICHMENT_CITY=LEXINGTON

# Optional: override scheduler cron expressions (UTC)
# IRS_CHECK_CRON=0 2 * * *
# ENRICHMENT_CRON=0 */6 * * *
# INDEX_REFRESH_CRON=0 3 * * 0
# SOLAR_CRON=0 */4 * * *
