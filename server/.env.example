PORT=3000
MONGODB_URI=mongodb://localhost:27017/solar_harvest

# Google API key — enable these APIs in your Google Cloud project:
#   - Solar API (https://developers.google.com/maps/documentation/solar)
#   - Geocoding API (https://developers.google.com/maps/documentation/geocoding)
# Both use the same key. Solar API: ~$0.004/req, Geocoding: ~$0.005/req
GOOGLE_SOLAR_API_KEY=your_key_here

# Scheduler cron expressions (all UTC)
IRS_CHECK_CRON=0 2 * * *        # Daily — IRS EO BMF check (updates 2nd Tuesday monthly)
ENRICHMENT_CRON=0 */6 * * *     # Every 6 hours — 990 XML enrichment batch
INDEX_REFRESH_CRON=0 3 * * 0    # Weekly Sunday — IRS filing index refresh
SOLAR_CRON=0 */4 * * *          # Every 4 hours — geocode (100) + solar (20) batch
