PORT=3000
MONGODB_URI=mongodb://localhost:27017/solar_harvest

# Free NREL PVWatts API key — sign up at https://developer.nrel.gov/signup/
# Falls back to DEMO_KEY (50 req/day) if not set.
NREL_API_KEY=your_key_here

# Optional: Google Maps Geocoding API key (paid fallback geocoder — not required)
# Enable "Geocoding API" in Google Cloud Console.
GOOGLE_MAPS_API_KEY=

# Restrict enrichment to one state (2-letter code, e.g. KY). Leave blank for all states.
ENRICHMENT_STATE=KY

# Scheduler cron expressions (all UTC)
IRS_CHECK_CRON=0 2 * * *        # Daily — IRS EO BMF check (updates 2nd Tuesday monthly)
ENRICHMENT_CRON=0 */6 * * *     # Every 6 hours — 990 XML enrichment batch
INDEX_REFRESH_CRON=0 3 * * 0    # Weekly Sunday — IRS filing index refresh
SOLAR_CRON=0 */4 * * *          # Every 4 hours — geocode (100) + solar (20) batch
